# ════════════════════════════════════════════════════════════════
# .gitignore - Archivos que NO se suben a Git
# ════════════════════════════════════════════════════════════════

# Python
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
env/
venv/
ENV/
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
*.egg-info/
.installed.cfg
*.egg

# Virtual Environment
venv/
.venv

# IDE
.vscode/
.idea/
*.swp
*.swo
*~

# Environment variables
.env
.env.local
.env.*.local

# Bases de datos
*.db
*.sqlite
*.sqlite3

# Videos (no guardar)
uploads/videos/
*.mp4
*.avi
*.mov

# Logs
logs/
*.log

# OS
.DS_Store
Thumbs.db

# Testing
.pytest_cache/
.coverage
htmlcov/

# Node (si usamos frontend después)
node_modules/
npm-debug.log
# Archivos SQL locales (no subir scripts con datos sensibles)
*.session.sql

# Carpeta de PDFs generados
generated_pdfs/
uploads/
